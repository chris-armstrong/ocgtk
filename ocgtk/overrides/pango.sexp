    (takri (version "1.32"))
    (bassa_vah (version "1.40"))
    (caucasian_albanian (version "1.40"))
    (duployan (version "1.40"))
    (elbasan (version "1.40"))
    (grantha (version "1.40"))
    (khojki (version "1.40"))
    (khudawadi (version "1.40"))
    (linear_a (version "1.40"))
    (mahajani (version "1.40"))
    (manichaean (version "1.40"))
    (mende_kikakui (version "1.40"))
    (modi (version "1.40"))
    (mro (version "1.40"))
