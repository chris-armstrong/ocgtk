  (enumeration TabAlign
    (right (version "1.50"))
    (center (version "1.50"))
    (decimal (version "1.50"))
  )

  (enumeration Variant
    (all_small_caps (version "1.50"))
    (petite_caps (version "1.50"))
    (all_petite_caps (version "1.50"))
    (unicase (version "1.50"))
    (title_caps (version "1.50"))
