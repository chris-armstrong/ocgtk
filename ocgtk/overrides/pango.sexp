  (enumeration Weight
    (thin (version "1.24"))
    (semilight (version "1.36.7"))
    (book (version "1.24"))
    (medium (version "1.24"))
    (ultraheavy (version "1.24"))
  )

  (bitfield FontMask
    (gravity (version "1.16"))
    (variations (version "1.42"))
  )

  (record Analysis
    (flags (version "1.16"))
    (script (version "1.18"))
  )

  (record GlyphVisAttr
    (is_color (version "1.50"))
