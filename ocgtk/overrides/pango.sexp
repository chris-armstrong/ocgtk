(overrides
  (library "Pango")

  (enumeration AttrType
    (font_features (version "1.38"))
    (foreground_alpha (version "1.38"))
    (background_alpha (version "1.38"))
    (allow_breaks (version "1.44"))
    (show (version "1.44"))
    (insert_hyphens (version "1.44"))
    (overline (version "1.46"))
    (overline_color (version "1.46"))
    (line_height (version "1.50"))
    (absolute_line_height (version "1.50"))
    (word (version "1.50"))
    (sentence (version "1.50"))
    (baseline_shift (version "1.50"))
    (font_scale (version "1.50"))
  )

  (enumeration BidiType
    (lri (version "1.48.6"))
    (rli (version "1.48.6"))
    (fsi (version "1.48.6"))
    (pdi (version "1.48.6"))
  )

